<section id="@Id" class="reveal section-opt mt-10 mb-6">
    <div class="manga-panel halftone gpu">

        <div class="about__header">
            <div>
                <span class="stamp anim-stamp">À propos</span>
                <h2 class="ink-title text-3xl mt-2">Mon parcours</h2>
                <p class="ink-muted mt-2 max-w-2xl">
                    Du Togo au Canada — un parcours de développeur guidé par la passion de l'architecture logicielle.
                </p>
            </div>
        </div>

        <!-- Profil -->
        <div class="about__profile manga-frame hatch gpu mt-4">
            <div class="hero__intro-label">Profil</div>
            <p class="about__bio">
                Étudiant au baccalauréat en informatique à l'Université Laval avec plus de <strong>2 ans d'expérience professionnelle</strong>
                en développement .NET et full-stack. Applications en production publiées sur <strong>Play Store et App Store</strong>.
                Lauréat du <strong>DigiEduHack 2025 (1er prix)</strong>. Passionné par la conception d'architectures robustes
                et de systèmes scalables — DDD, CQRS, SOLID.
            </p>
        </div>

        <!-- Distinction -->
        <div class="about__distinction mt-4">
            <div class="manga-frame gpu about__award">
                <div class="about__award-icon">
                    <span aria-hidden="true">★</span>
                </div>
                <div>
                    <div class="ink-title text-sm">Lauréat DigiEduHack 2025</div>
                    <div class="ink-muted text-xs mt-1">1er prix — "The Food Challenge"</div>
                    <div class="ink-dim text-xs mt-1">
                        Développé en solo Équi-Assiette, un simulateur éducatif de composition de repas équilibrés
                        ciblant les jeunes adultes et familles canadiennes.
                    </div>
                </div>
            </div>
        </div>

        <!-- Timeline -->
        <div class="about__timeline mt-6">
            <div class="about__timeline-title">
                <div class="ink-title text-lg">Expérience & Formation</div>
                <div class="ink-dim text-xs font-black uppercase tracking-wide">Timeline</div>
            </div>

            <div class="about__timeline-track">

                <!-- Formation Laval -->
                <div class="about__tl-item about__tl-item--edu">
                    <div class="about__tl-dot"></div>
                    <div class="about__tl-card manga-frame gpu">
                        <div class="about__tl-top">
                            <span class="stamp stamp--ink text-xs">Formation</span>
                            <span class="ink-dim text-xs font-bold">2025 — 2028</span>
                        </div>
                        <div class="ink-title text-sm mt-2">Baccalauréat en informatique</div>
                        <div class="ink-muted text-xs mt-1">Université Laval, Québec, Canada</div>
                    </div>
                </div>

                <!-- BH Consulting -->
                <div class="about__tl-item">
                    <div class="about__tl-dot"></div>
                    <div class="about__tl-card manga-frame gpu">
                        <div class="about__tl-top">
                            <span class="stamp text-xs">Freelance</span>
                            <span class="ink-dim text-xs font-bold">Mai — Déc. 2025</span>
                        </div>
                        <div class="ink-title text-sm mt-2">Développeur full-stack (Laravel / Flutter)</div>
                        <div class="ink-muted text-xs mt-1">BH Consulting, Lomé, Togo</div>
                        <ul class="about__tl-list mt-2">
                            <li>API REST backend de Style Charm — déployée sur Play Store et App Store</li>
                            <li>Architecture DDD/CQRS avec principes SOLID et DRY</li>
                            <li>Contribution frontend Flutter + intégration de bout en bout</li>
                            <li>Développement en parallèle de Recycle (sensibilisation au recyclage)</li>
                        </ul>
                    </div>
                </div>

                <!-- SIC -->
                <div class="about__tl-item">
                    <div class="about__tl-dot"></div>
                    <div class="about__tl-card manga-frame gpu">
                        <div class="about__tl-top">
                            <span class="stamp text-xs">Stage</span>
                            <span class="ink-dim text-xs font-bold">Avr. — Août 2024</span>
                        </div>
                        <div class="ink-title text-sm mt-2">Développeur backend .NET</div>
                        <div class="ink-muted text-xs mt-1">SIC, Lomé, Togo</div>
                        <ul class="about__tl-list mt-2">
                            <li>APIs RESTful (ASP.NET Core) avec DDD, CQRS, MediatR, FluentValidation</li>
                            <li>Authentification JWT + documentation Swagger/OpenAPI</li>
                            <li>Optimisation SQL Server et Entity Framework Core</li>
                        </ul>
                    </div>
                </div>

                <!-- EVENOU-GROUP -->
                <div class="about__tl-item">
                    <div class="about__tl-dot"></div>
                    <div class="about__tl-card manga-frame gpu">
                        <div class="about__tl-top">
                            <span class="stamp text-xs">Stage</span>
                            <span class="ink-dim text-xs font-bold">Août 2023 — Fév. 2024</span>
                        </div>
                        <div class="ink-title text-sm mt-2">Développeur .NET / Gestion de projet</div>
                        <div class="ink-muted text-xs mt-1">EVENOU-GROUP, Lomé, Togo</div>
                        <ul class="about__tl-list mt-2">
                            <li>Système municipal complet (C#, Blazor, ASP.NET Core, SQL Server)</li>
                            <li>Architecture DDD + CQRS (MediatR, FluentValidation)</li>
                            <li>Gestion de sprints (GitLab, Microsoft Project) et analyse des besoins</li>
                        </ul>
                    </div>
                </div>

                <!-- Formation Lomé -->
                <div class="about__tl-item about__tl-item--edu">
                    <div class="about__tl-dot"></div>
                    <div class="about__tl-card manga-frame gpu">
                        <div class="about__tl-top">
                            <span class="stamp stamp--ink text-xs">Formation</span>
                            <span class="ink-dim text-xs font-bold">2019 — 2024</span>
                        </div>
                        <div class="ink-title text-sm mt-2">Licence professionnelle en génie logiciel</div>
                        <div class="ink-muted text-xs mt-1">EPL — Université de Lomé, Togo</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Compétences techniques -->
        <div class="about__skills mt-6">
            <div class="about__timeline-title">
                <div class="ink-title text-lg">Compétences</div>
                <div class="ink-dim text-xs font-black uppercase tracking-wide">Techniques</div>
            </div>

            <div class="about__skills-grid mt-3">
                <div class="about__skill-card manga-frame gpu">
                    <div class="ink-title text-xs">Langages</div>
                    <div class="about__skill-tags mt-2">
                        <span class="about__skill-tag">C#</span>
                        <span class="about__skill-tag">PHP</span>
                        <span class="about__skill-tag">TypeScript</span>
                        <span class="about__skill-tag">Python</span>
                        <span class="about__skill-tag">Java</span>
                        <span class="about__skill-tag">Dart</span>
                        <span class="about__skill-tag">SQL</span>
                    </div>
                </div>

                <div class="about__skill-card manga-frame gpu">
                    <div class="ink-title text-xs">Frameworks</div>
                    <div class="about__skill-tags mt-2">
                        <span class="about__skill-tag">ASP.NET Core</span>
                        <span class="about__skill-tag">Blazor</span>
                        <span class="about__skill-tag">EF Core</span>
                        <span class="about__skill-tag">Laravel</span>
                        <span class="about__skill-tag">Next.js</span>
                        <span class="about__skill-tag">Flutter</span>
                        <span class="about__skill-tag">MediatR</span>
                    </div>
                </div>

                <div class="about__skill-card manga-frame gpu">
                    <div class="ink-title text-xs">Méthodologies</div>
                    <div class="about__skill-tags mt-2">
                        <span class="about__skill-tag">DDD</span>
                        <span class="about__skill-tag">CQRS</span>
                        <span class="about__skill-tag">SOLID</span>
                        <span class="about__skill-tag">DRY</span>
                        <span class="about__skill-tag">Scrum/Agile</span>
                    </div>
                </div>

                <div class="about__skill-card manga-frame gpu">
                    <div class="ink-title text-xs">Bases de données</div>
                    <div class="about__skill-tags mt-2">
                        <span class="about__skill-tag">SQL Server</span>
                        <span class="about__skill-tag">MySQL</span>
                        <span class="about__skill-tag">PostgreSQL</span>
                        <span class="about__skill-tag">MariaDB</span>
                    </div>
                </div>

                <div class="about__skill-card manga-frame gpu">
                    <div class="ink-title text-xs">Outils</div>
                    <div class="about__skill-tags mt-2">
                        <span class="about__skill-tag">Git</span>
                        <span class="about__skill-tag">GitHub</span>
                        <span class="about__skill-tag">GitLab</span>
                        <span class="about__skill-tag">Docker</span>
                        <span class="about__skill-tag">Swagger/OpenAPI</span>
                        <span class="about__skill-tag">Linux</span>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

@code {
    [Parameter] public string Id { get; set; } = "about";
}
