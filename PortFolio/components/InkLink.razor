@* A plain internal anchor. Plain left-clicks are intercepted in JS (ink.js) to play
   the wipe transition; Ctrl/Cmd/Shift/middle-clicks fall through to the browser so
   "open in new tab" works as users expect. See InkNavigator. *@

<a href="@Href" class="@Class" data-inklink="true" @attributes="AdditionalAttributes">
    @ChildContent
</a>

@code {
    [Parameter, EditorRequired] public string Href { get; set; } = "/";
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }
}
