@page "/library/{Slug}"
@using PortFolio.components
@using PortFolio.Services
@using PortFolio.Models
@inject NavigationManager Nav

<PageTitle>@(_book?.Title ?? "Livre introuvable")</PageTitle>

@if (_book == null)
{
    <div class="p-8 text-center">
        <p class="ink-title text-xl">Livre introuvable...</p>
        <InkLink Href="/#library" Class="ink-btn ink-btn--ghost mt-4">Retour</InkLink>
    </div>
}
else
{
    <div class="book-table">
    <!-- Top bar (sur la table, au-dessus du livre) -->
    <div class="bookdetail__topbar">
        <InkLink Href="/#library" Class="ink-btn ink-btn--ghost gpu text-xs">
            <span aria-hidden="true" class="ink-btn__glyph">←</span>
            <span class="ink-btn__text">Bibliothèque</span>
        </InkLink>

        <div class="bookdetail__topbar-right">
            @if (!string.IsNullOrEmpty(_book.DemoLink))
            {
                <a href="@_book.DemoLink" target="_blank" class="ink-btn ink-btn--solid gpu text-xs">
                    <span class="ink-btn__text">Voir le site</span>
                    <span aria-hidden="true" class="ink-btn__glyph">→</span>
                </a>
            }
            @if (!string.IsNullOrEmpty(_book.SourceCodeLink))
            {
                <a href="@_book.SourceCodeLink" target="_blank" class="ink-btn ink-btn--ghost gpu text-xs">
                    <span class="ink-btn__text">Code Source</span>
                    <span aria-hidden="true" class="ink-btn__glyph">↗</span>
                </a>
            }
        </div>
    </div>

    <!-- Le livre ouvert (pages vieillies + reliure + élévation) -->
    <article class="open-spread">
    <!-- Hero du projet -->
    <section class="bookdetail__hero reveal is-in section-opt manga-panel halftone gpu">
        <div class="bookdetail__hero-inner">
            <div class="bookdetail__hero-left">
                <div class="bookdetail__hero-meta">
                    <span class="stamp anim-stamp">@_book.StampLabel</span>
                    <span class="ink-dim text-xs font-black uppercase tracking-wide">@_book.Year • @_book.Duration</span>
                </div>
                <h1 class="ink-title bookdetail__hero-title">@_book.Title</h1>
                <p class="bookdetail__hero-subtitle">@_book.DescriptionTitle</p>
            </div>

            @if (_book.KeyMetrics.Count > 0)
            {
                <div class="bookdetail__hero-metrics">
                    @foreach (var metric in _book.KeyMetrics)
                    {
                        <div class="bookdetail__metric">
                            <span class="bookdetail__metric-text">@metric</span>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Meta cards -->
        <div class="bookdetail__meta-row">
            <div class="bookdetail__meta-card">
                <div class="bookdetail__meta-label">Rôle</div>
                <div class="bookdetail__meta-value">@_book.Role</div>
            </div>
            <div class="bookdetail__meta-card">
                <div class="bookdetail__meta-label">Contexte</div>
                <div class="bookdetail__meta-value">@_book.Context</div>
            </div>
            <div class="bookdetail__meta-card">
                <div class="bookdetail__meta-label">Année</div>
                <div class="bookdetail__meta-value">@_book.Year</div>
            </div>
            <div class="bookdetail__meta-card">
                <div class="bookdetail__meta-label">Durée</div>
                <div class="bookdetail__meta-value">@_book.Duration</div>
            </div>
        </div>
    </section>

    <!-- Contenu principal en deux colonnes -->
    <div class="bookdetail__content mt-4">
        <!-- Colonne gauche : Narration + Contributions -->
        <div class="bookdetail__main">
            <div class="manga-frame hatch gpu bookdetail__section">
                <div class="folio-section-head">
                    <div class="ink-title text-lg">Narration</div>
                    <div class="ink-dim text-xs font-black uppercase tracking-wide">histoire</div>
                </div>
                <div class="folio-body mt-3">
                    @((MarkupString)_book.NarrationHtml)
                </div>
            </div>

            <div class="manga-frame hatch gpu bookdetail__section mt-4">
                <div class="folio-section-head">
                    <div class="ink-title text-lg">Contributions</div>
                    <div class="ink-dim text-xs font-black uppercase tracking-wide">rôle & livrables</div>
                </div>
                @if (_book.Contributions.Count == 0)
                {
                    <div class="ink-dim text-sm font-bold mt-3">Contributions à venir.</div>
                }
                else
                {
                    <ul class="folio-bullets mt-3">
                        @foreach (var bullet in _book.Contributions)
                        {
                            <li>@bullet</li>
                        }
                    </ul>
                }
            </div>
        </div>

        <!-- Colonne droite : Stack technique -->
        <div class="bookdetail__sidebar">
            <div class="manga-frame hatch gpu bookdetail__section">
                <div class="folio-section-head">
                    <div class="ink-title text-lg">Stack</div>
                    <div class="ink-dim text-xs font-black uppercase tracking-wide">technique</div>
                </div>
                <div class="bookdetail__stack-list mt-3">
                    @foreach (var item in _book.Stack)
                    {
                        <div class="bookdetail__stack-item">
                            <div class="bookdetail__stack-icon-wrap">
                                <img src="@item.IconSrc" class="bookdetail__stack-icon" alt="@item.Name" />
                            </div>
                            <div>
                                <div class="bookdetail__stack-name">@item.Name</div>
                                <div class="bookdetail__stack-usage">@item.UsedFor</div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_book.DemoLink) || !string.IsNullOrEmpty(_book.SourceCodeLink))
            {
                <div class="manga-frame gpu bookdetail__section mt-4">
                    <div class="folio-section-head">
                        <div class="ink-title text-lg">Explorer</div>
                        <div class="ink-dim text-xs font-black uppercase tracking-wide">liens</div>
                    </div>
                    <div class="bookdetail__links mt-3">
                        @if (!string.IsNullOrEmpty(_book.DemoLink))
                        {
                            <a href="@_book.DemoLink" target="_blank" class="ink-btn ink-btn--solid gpu text-xs">
                                <span class="ink-btn__text">Voir le site</span>
                                <span aria-hidden="true" class="ink-btn__glyph">→</span>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(_book.SourceCodeLink))
                        {
                            <a href="@_book.SourceCodeLink" target="_blank" class="ink-btn ink-btn--ghost gpu text-xs">
                                <span class="ink-btn__text">Code Source</span>
                                <span aria-hidden="true" class="ink-btn__glyph">↗</span>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    </article>

    <!-- Navigation Suivant / Precedent (sur la table, sous le livre) -->
    <div class="book-nav mt-6">
        @if (_prev != null)
        {
            <InkLink Href="@($"/library/{_prev.Slug}")" Class="book-nav__link">
                <span class="ink-btn__glyph">←</span>
                <div>
                    <span class="book-nav__label">Précédent</span>
                    @_prev.Title
                </div>
            </InkLink>
        }
        else
        {
            <div></div>
        }

        @if (_next != null)
        {
            <InkLink Href="@($"/library/{_next.Slug}")" Class="book-nav__link text-right">
                <div>
                    <span class="book-nav__label">Suivant</span>
                    @_next.Title
                </div>
                <span class="ink-btn__glyph">→</span>
            </InkLink>
        }
    </div>
    </div>

}

@code {
    [Parameter] public string Slug { get; set; } = "";

    private BookData? _book;
    private BookData? _next;
    private BookData? _prev;

    protected override void OnParametersSet()
    {
        _book = BookRepository.GetBySlug(Slug);
        if (_book != null)
        {
            _next = BookRepository.GetNext(Slug);
            _prev = BookRepository.GetPrevious(Slug);
        }
    }
}
