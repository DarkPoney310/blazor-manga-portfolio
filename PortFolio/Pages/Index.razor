@page "/"
@using PortFolio.components
@inject IJSRuntime JS

<PageTitle>Isaac L. Lawson Attiogbe — Software Engineer</PageTitle>

<SocialIconButtons />

<HeroSection Title="ISAAC L. LAWSON ATTIOGBE"
             Subtitle="Software Engineer — Spécialisé en Backend & Architecture"
             Location="Québec, Canada"
             Email="lawsonisaac89@gmail.com"
             PrimaryHref="#about"
             SecondaryHref="#contact" />

<AboutSection Id="about" />

<LibrarySection Id="library" />

<ContactSection Id="contact"
                Email="lawsonisaac89@gmail.com"
                Phone="+1 (263) 880-4848"
                Location="Québec, Canada"
                GitHubUrl="https://github.com/DarkPoney310"
                LinkedInUrl="https://www.linkedin.com/in/lat%C3%A9-isaac-lawson-attiogbe-606404232" />

<Live2DDisplay Source="/live2d/bilibili-22/index.json"
               Scale="0.25"
               IsDraggable="true"
               Position="LivePosition.BottomRight"
               AddHitAreaFrames="false"
               XOffset="20"
               YOffset="20"
               BackgroundAlpha="false" />

@code {
    private IJSObjectReference? _mod;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _mod = await JS.InvokeAsync<IJSObjectReference>("import", "./js/ink.js");
        await _mod.InvokeVoidAsync("observeReveals");
        await _mod.InvokeVoidAsync("initStackMarquees");
    }
}
